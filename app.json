{
  "expo": {
    "name": "Dino Calm",
    "description": "A gentle self-care app where a tiny dino helps you check in with your mood and take small calming steps.",
    "slug": "dino-calm",
    "version": "2.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#EEF8DD",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF8DD"
    },
    "ios": {
      "bundleIdentifier": "com.nuradil.dinocalm",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EEF8DD"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nuradil.dinocalm"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ]
  }
}
